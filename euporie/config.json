{
    "color_scheme": "light",
    "log_file": "/tmp/euporie.log",
    "log_level": "debug",
    "enable_language_servers": true,
    "autosuggest": "smart",
    "autocomplete": true,
    "graphics": "kitty",
    "edit_mode": "micro",
    "key_bindings": {
        "euporie.apps.notebook.app.NotebookApp": {
            "show-context-help": ["f1"],
            "toggle-menu": ["f10"]
        },
        "euporie.core.widgets.inputs.KernelInput": {
            "backward-delete-word": ["A-backspace"],
            "cursor-left-word": ["A-left"],
            "cursor-right-word": ["A-right"],
            "cursor-left-word-extend": ["A-s-left"],
            "cursor-right-word-extend": ["A-s-right"]
        }
    }
}
